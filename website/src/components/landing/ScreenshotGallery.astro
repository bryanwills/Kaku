---
interface Props { lang?: string; }
const { lang = 'zh-CN' } = Astro.props;
const isEn = lang === 'en';

interface Shot { src: string; alt: string; }
const shots: Shot[] = isEn ? [
  { src: '/shots/kaku-dark.webp', alt: 'Kaku dark theme with Claude Code and Codex panes' },
  { src: '/shots/kaku-light.webp', alt: 'Kaku light theme with Claude Code, Codex, and terminal tools' },
] : [
  { src: '/shots/kaku-dark.webp', alt: 'Kaku 深色主题，展示 Claude Code 与 Codex 分屏' },
  { src: '/shots/kaku-light.webp', alt: 'Kaku 浅色主题，展示 Claude Code、Codex 与终端工具' },
];
---

<section class="sg-section">
  <div class="kk-container-wide">
    <div class="sg-tag">{isEn ? '[6] Real Screenshots' : '[6] 真实截图'}</div>
    <h2>{isEn ? 'Dark or light, same AI-first workflow' : '深色或浅色，都是同一套 AI 工作流'}</h2>
    <div class="gallery">
      {shots.map(shot => (
        <figure class="shot">
          <img src={shot.src} alt={shot.alt} loading="lazy" />
        </figure>
      ))}
    </div>
  </div>
</section>

<style>
  .sg-section {
    padding: var(--kk-space-16) 0;
    border-bottom: 1px dashed var(--kk-border);
  }
  .sg-tag {
    color: var(--kk-accent);
    font-family: var(--kk-font-mono);
    font-size: 11px;
    letter-spacing: 1px;
    opacity: 0.7;
    margin-bottom: var(--kk-space-3);
    text-align: center;
  }
  h2 {
    color: var(--kk-text);
    font-size: 24px;
    text-align: center;
    margin: 0 0 var(--kk-space-8);
  }
  .gallery {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: var(--kk-space-4);
    max-width: 1040px;
    margin: 0 auto;
  }
  .shot {
    margin: 0;
    background: var(--kk-bg-card);
    border: 1px solid var(--kk-border);
    border-radius: var(--kk-radius-md);
    overflow: hidden;
    aspect-ratio: 2920 / 1812;
  }
  .shot img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  @media (max-width: 720px) {
    .gallery { grid-template-columns: 1fr; }
  }
</style>
